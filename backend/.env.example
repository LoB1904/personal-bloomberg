# --- Copia questo file in .env e compila i valori ---
# .env è in .gitignore, NON sarà mai committato. Le credenziali stanno SOLO lì.
# Questo file (.env.example) è un TEMPLATE: mettici solo placeholder, mai valori reali.

# === Supabase (Fase 0) ===
# Da Supabase Dashboard > Project Settings > API
SUPABASE_URL=https://your_project_ref.supabase.co/rest/v1/
SUPABASE_ANON_KEY=your_supabase_anon_key            # public anon key (read-only via RLS)
SUPABASE_SERVICE_KEY=your_supabase_service_role_key # service_role key — POTERI ADMIN, mai esporre client side

# Connessione SQLAlchemy diretta (per ingestione bulk)
# Da Supabase Dashboard > Project Settings > Database > Connection string > URI
# IMPORTANTE: usa la versione "Transaction pooler" (port 6543) per script batch,
# "Direct connection" (port 5432) solo per long-lived connections
DATABASE_URL=postgresql://postgres.your_project_ref:your_db_password@aws-1-eu-central-1.pooler.supabase.com:6543/postgres


# === Fonte dati primaria — Fase 1 ===
# Scegline UNA tra EODHD e FMP dopo i test in Fase 0
EODHD_API_KEY=                            # https://eodhd.com (~20$/mese)
FMP_API_KEY=                              # https://site.financialmodelingprep.com (~14$/mese)

# === Fonti dati secondarie — Fase 1 ===
FRED_API_KEY=                             # https://fred.stlouisfed.org (gratuito, illimitato)

# === AI Layer — Fase 4 ===
ANTHROPIC_API_KEY=your_anthropic_api_key  # https://console.anthropic.com

# === Notifiche — Fase 4 (alert Telegram) ===
# Crea il bot con @BotFather → ottieni il token.
# chat_id: scrivi al bot, poi apri https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id

# === App config ===
APP_ENV=dev                               # dev | prod
LOG_LEVEL=INFO
